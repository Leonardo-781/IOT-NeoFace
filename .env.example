# TEMPLATE - Copie como .env e configure com seus valores
# ⚠️ NUNCA commite dados sensíveis! Use .env para valores locais.

# ===== CONFIGURACAO PARA SERVER-STI (REMOTO) =====
# Deploy em servidor remoto via SSH + Docker

# Core stack - Database
POSTGRES_DB=iot_monitoring
POSTGRES_USER=iot_user
POSTGRES_PASSWORD=COLOQUE_SENHA_SEGURA_AQUI
DB_HOST=192.168.1.10
DB_PORT=5432

# MQTT Broker
MQTT_HOST=192.168.1.10
MQTT_PORT=1883

# Backend / UI
LOGIN_USER=admin
LOGIN_PASSWORD=COLOQUE_SENHA_SEGURA_AQUI
BACKEND_PORT=3000
GATEWAY_PORT=3001
NODE_ENV=production

# Ingest Service
INGEST_HTTP_PORT=3102

# Optional tuning
SIMULATION_INTERVAL_MS=5000
COMMAND_ACK_DELAY_MS=1200
MAX_TELEMETRY_POINTS=120
DB_RETENTION_DAYS=30

# Para ESP32/IoT
API_GATEWAY_URL=http://192.168.1.10:3001
BROKER_URL=tcp://192.168.1.10:1883

# Server-STI
SERVER_STI_IP=192.168.1.10
SERVER_STI_HOST=server-sti